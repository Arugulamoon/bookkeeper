{{template "base" .}}

{{define "title"}}
  Sports Membership
{{end}}

{{define "main"}}

  {{$membership := .Membership}}

  {{with .Membership}}
    <div>
      <label>Name:</label>
      {{.Name}}
    </div>

    <div>
      <label>Season:</label>
      {{.SeasonYear}} {{.SeasonType}}
    </div>

    <div>
      <label>Location:</label>
      {{.Location}}
    </div>
  {{end}}

  {{if .Games}}
    <h2>Games</h2>
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>Date</th>
          <th>Start Time</th>
          <th>Opponent</th>
          <th>Notes</th>
          <th>Location</th>
          <th>Event</th>
        </tr>
      </thead>
      <tbody class="table-group-divider">
        {{range .Games}}
          <tr>
            <td class="text-nowrap">{{formatDate .Date}}</td>
            <td class="text-nowrap">{{.StartTime}}</td>
            <td class="text-nowrap">{{.Opponent}}</td>
            <td>{{.Notes}}</td>
            <td class="text-nowrap">
              {{if eq .Location ""}}
                {{$membership.Location}}
              {{else}}
                {{.Location}}
              {{end}}
            </td>
            <td class="text-nowrap">{{.EventId}}</td>
          </tr>
        {{end}}
      </tbody>
    </table>
  {{end}}

{{end}}
