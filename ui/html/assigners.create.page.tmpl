{{template "base" .}}

{{define "title"}}
  Create Assigner
{{end}}

{{define "main"}}

  <form action='/assigner/create' method='POST'>
    <input type='hidden' name='searchedFor' value='{{.SearchedFor}}'>

    <div>
      <label>Name:</label>
      <input type='text' name='name'>
    </div>

    <div>
      <label>Bank Transaction Description:</label> {{.SearchedFor}}
      <input type='hidden' name='bankTxDesc' value='{{.SearchedFor}}'>
    </div>

    <div>
      <label>Account:</label>
      <select name='acct'>
        <option value='' selected></option>
        {{range .Accounts}}
          <option value='{{.AccountType}}#{{.Name}}'>
            {{.AccountType}}: {{.Name}}
          </option>
        {{end}}
      </select>
    </div>

    <div>
      <input type='submit' value='Create Assigner'>
    </div>
  </form>

  <h2>Journal Account Entries</h2>
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Date</th>
        <th>Description</th>
        <th>Account Type</th>
        <th>Account</th>
        <th>Amount</th>
        <th>Bank Account</th>
      </tr>
    </thead>
    <tbody class="table-group-divider">
      {{range .JournalAccountEntries}}
        <tr>
          <td class="text-nowrap">{{formatDate .Date}}</td>
          <td>{{.Description}}</td>
          <td>{{.AccountType}}</td>
          <td>{{.AccountName}}</td>
          <td class="text-nowrap">
            {{if eq .AccountBalanceType .BalanceType}}
              <span style="color: green;">
                ${{printf "%.2f" .Amount}}
              </span>
            {{else}}
              <span style="color: red;">
                {{printf "$-%.2f" .Amount}}
              </span>
            {{end}}
          </td>
          <td class="text-nowrap">{{.BankAccountName}}</td>
        </tr>
      {{end}}
    </tbody>
  </table>

{{end}}
