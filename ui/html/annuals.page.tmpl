{{template "base" .}}

{{define "title"}}
  Annual Report
{{end}}

{{define "main"}}

  {{$annualReportYear := .AnnualReportYear}}

  <h2>{{$annualReportYear}}</h2>

  <h3>Assets</h3>
  <table class="table table-striped-columns table-hover">
    <thead>
      <tr>
        <th>Account</th>
        <th>Jan</th>
        <th>Feb</th>
        <th>Mar</th>
        <th>Apr</th>
        <th>May</th>
        <th>Jun</th>
        <th>Jul</th>
        <th>Aug</th>
        <th>Sep</th>
        <th>Oct</th>
        <th>Nov</th>
        <th>Dec</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody class="table-group-divider">
      {{range .AccountMonthlyTotals.Asset}}
        {{$account := .Account}}
        <tr>
          <th>{{$account.Name}}</th>
          {{range $i, $v := .MonthlyTotals}}
            {{if . }}
              <td>
                <a href='/journal/account/{{$account.AccountType}}/{{$account.Name}}?year={{$annualReportYear}}&month={{add $i 1}}'>
                  ${{printf "%.2f" .}}
                </a>
              </td>
            {{else}}
              <td></td>
            {{end}}
          {{end}}
          <td>${{printf "%.2f" .AnnualTotal}}</td>
        </tr>
      {{end}}
      <tr>
        <th>Total</th>
        {{range .AccountTypeMonthlyTotals.Asset.MonthlyTotals}}
          <td>${{printf "%.2f" .}}</td>
        {{end}}
        <td>${{printf "%.2f" .AccountTypeMonthlyTotals.Asset.AnnualTotal}}</td>
      </tr>
    </tbody>
  </table>

