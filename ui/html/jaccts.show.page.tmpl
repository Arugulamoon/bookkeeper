{{template "base" .}}

{{define "title"}}
  Journal Account Entries
{{end}}

{{define "main"}}

  {{$fromUrl := .FromUrl}}

  <h2>{{.Account.AccountType}}: {{.Account.Name}}</h2>
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Date</th>
        <th>Description</th>
        <th>Amount</th>
        <th>Bank Account</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody class="table-group-divider">
      {{range .JournalAccountEntries}}
        <tr>
          <td class="text-nowrap">{{formatDate .Date}}</td>
          <td>
            <a href='/assigner/create?search={{.Description}}'>
              {{.Description}}
            </a>
          </td>
          <td class="text-nowrap">
            {{if eq .AccountBalanceType .BalanceType}}
              <span style="color: green;">
                ${{printf "%.2f" .Amount}}
              </span>
            {{else}}
              <span style="color: red;">
                {{printf "$-%.2f" .Amount}}
              </span>
            {{end}}
          </td>
          <td class="text-nowrap">{{.BankAccountName}}</td>
          <td>
            <a href="/journal/account/entries/{{.Id}}/edit?fromUrl={{$fromUrl}}">
              Edit
            </a> |
            <a href="/journal/account/entries/{{.Id}}/split?fromUrl={{$fromUrl}}">
              Split
            </a>
          </td>
        </tr>
      {{end}}
    </tbody>
  </table>

{{end}}
